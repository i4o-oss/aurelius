{
	"name": "ui",
	"version": "0.0.0",
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"style": "./dist/main.css",
	"exports": {
		".": "./dist/index.js",
		"./main.css": "./dist/main.css"
	},
	"types": "./dist/index.d.ts",
	"license": "MIT",
	"scripts": {
		"build": "concurrently \"npm run build:css\" \"tsup index.tsx --format esm,cjs --dts --external react\"",
		"build:css": "tailwindcss -m -i ./styles/main.css -o ./dist/main.css",
		"dev": "concurrently \"npm run dev:css\" \"tsup index.tsx --format esm,cjs --watch --dts --external react\"",
		"dev:css": "tailwindcss -w -i ./styles/main.css -o ./dist/main.css",
		"lint": "eslint *.ts*"
	},
	"devDependencies": {
		"@aurelius/eslint-config": "workspace:*",
		"@aurelius/tsconfig": "workspace:*",
		"@types/react": "^18.0.17",
		"@types/react-dom": "^18.0.6",
		"autoprefixer": "^10.4.13",
		"concurrently": "^7.6.0",
		"eslint": "^8.30.0",
		"postcss": "^8.4.20",
		"react": "^18.2.0",
		"tailwindcss": "^3.2.4",
		"tsup": "^6.5.0",
		"typescript": "^4.5.2"
	}
}
