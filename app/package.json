{
	"name": "synthwave-stack",
	"private": true,
	"description": "",
	"license": "MIT",
	"sideEffects": false,
	"scripts": {
		"build": "npm run build:css && remix build",
		"build:css": "tailwindcss -m -i ./styles/app.css -o app/styles/app.css",
		"dev": "concurrently \"npm run dev:css\" \"remix dev\"",
		"dev:css": "tailwindcss -w -i ./styles/app.css -o app/styles/app.css",
		"format": "prettier --write .",
		"lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
		"postinstall": "remix setup node",
		"typecheck": "tsc -b"
	},
	"dependencies": {
		"@aurelius/ui": "workspace:*",
		"@aws-sdk/client-s3": "3.204.0",
		"@aws-sdk/lib-storage": "3.204.0",
		"@remix-run/node": "1.7.5",
		"@remix-run/react": "1.7.5",
		"@remix-run/vercel": "1.7.5",
		"@sendgrid/client": "7.7.0",
		"@sendgrid/mail": "7.7.0",
		"@tailwindcss/aspect-ratio": "0.4.2",
		"@vercel/node": "2.6.2",
		"aws-sdk": "2.1249.0",
		"classnames": "2.3.2",
		"formidable": "2.0.1",
		"framer-motion": "7.6.5",
		"nanoid": "4.0.0",
		"react": "18.2.0",
		"react-dom": "18.2.0",
		"react-feather": "2.0.10",
		"react-icons": "4.6.0",
		"remix": "^1.9.0",
		"remix-auth": "3.3.0",
		"remix-auth-email-link": "1.5.0",
		"remix-auth-google": "1.1.0",
		"remix-auth-twitter": "0.1.0",
		"tailwindcss-radix": "2.6.1",
		"zod": "^3.20.2",
		"zodix": "^0.3.2"
	},
	"devDependencies": {
		"@aurelius/eslint-config": "workspace:*",
		"@aurelius/tsconfig": "workspace:*",
		"@remix-run/dev": "1.7.5",
		"@remix-run/serve": "1.7.5",
		"@tauri-apps/cli": "^1.2.2",
		"@types/formidable": "2.0.5",
		"@types/react": "18.0.25",
		"@types/react-dom": "18.0.8",
		"autoprefixer": "10.4.13",
		"concurrently": "7.5.0",
		"cross-env": "7.0.3",
		"npm-run-all": "4.1.5",
		"postcss": "8.4.18",
		"prettier": "2.7.1",
		"prettier-plugin-tailwindcss": "0.1.13",
		"prisma": "4.5.0",
		"tailwindcss": "3.2.2",
		"ts-node": "10.9.1",
		"typescript": "4.8.4"
	},
	"packageManager": "yarn@3.2.1",
	"engines": {
		"node": ">=14"
	}
}
